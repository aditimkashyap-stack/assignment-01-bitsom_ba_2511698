        "\n",
        "    cell_entry = {\n",
        "        \"cell_type\": cell_type_nb,\n",
        "        \"metadata\": {},\n",
        "        \"source\": cell_content_lines\n",
        "    }\n",
        "\n",
        "    if cell_type_nb == \"code\":\n",
        "        cell_entry[\"execution_count\"] = None # No execution count provided, assume null\n",
        "        outputs = []\n",
        "        if cell_data[\"standard_output\"]:\n",
        "            outputs.append({\n",
        "                \"name\": \"stdout\",\n",
        "                \"output_type\": \"stream\",\n",
        "                \"text\": cell_data[\"standard_output\"].splitlines(keepends=True)\n",
        "            })\n",
        "        if cell_data[\"standard_error\"]:\n",
        "            outputs.append({\n",
        "                \"name\": \"stderr\",\n",
        "                \"output_type\": \"stream\",\n",
        "                \"text\": cell_data[\"standard_error\"].splitlines(keepends=True)\n",
        "            })\n",
        "        if cell_data[\"traceback\"]:\n",
        "            ename = \"Error\"\n",
        "            evalue = \"\"\n",
        "            traceback_lines = cell_data[\"traceback\"].splitlines(keepends=True)\n",
        "            if traceback_lines:\n",
        "                last_line = traceback_lines[-1].strip()\n",
        "                if \":\" in last_line:\n",
        "                    parts = last_line.split(\":\", 1)\n",
        "                    if len(parts) == 2:\n",
        "                        ename = parts[0].strip()\n",
        "                        evalue = parts[1].strip()\n",
